# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls.
# Get your API key from https://platform.deepseek.com/
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# WeChat Mini Program credentials
# Get these from WeChat Open Platform https://mp.weixin.qq.com/
WECHAT_APP_ID="YOUR_WECHAT_APP_ID"
WECHAT_APP_SECRET="YOUR_WECHAT_APP_SECRET"

# MySQL Database Configuration
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="YOUR_DB_PASSWORD"
DB_NAME="tarot"

# Admin Authentication Configuration
# IMPORTANT: Change these credentials before deploying to production!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
ADMIN_TOKEN_SECRET="CHANGE_THIS_TO_A_RANDOM_STRING"

# 微信订阅消息配置
# 从微信公众平台 -> 功能 -> 订阅消息 获取
SUBSCRIBE_LOGIN_TMPL_ID=""
SUBSCRIBE_QUOTA_TMPL_ID=""
LOGIN_FIELD_TIME="time2"
LOGIN_FIELD_NAME="thing4"
QUOTA_FIELD_REMAINING="number1"
QUOTA_FIELD_USED="number2"
